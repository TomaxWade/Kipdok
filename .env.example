# Run `bash scripts/bootstrap-local.sh` to generate a local `.env`
# with a random SESSION_SECRET and an initial admin password.

DATABASE_URL="file:./data/db/app.db"
DATA_ROOT="./data"
SESSION_SECRET="replace-with-a-long-random-secret"
INITIAL_ADMIN_USERNAME="admin"
INITIAL_ADMIN_PASSWORD="replace-with-a-strong-password"
APP_NAME="Kipdok"
APP_BASE_URL="http://127.0.0.1:3000/kipdok"
MAX_UPLOAD_SIZE_MB="100"
